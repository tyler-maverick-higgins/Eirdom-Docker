# Docker socket group on the host:
# stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# Absolute path to the Eirdom-Docker checkout on eirdom-docker-01.
# Matching host/container paths are required for reliable Compose bind mounts.
EIRDOM_DOCKER_REPO=/home/dockeradm/eirdom/docker

# -----------------------------------------------------------------------------
# Dockhand behavior
# -----------------------------------------------------------------------------
DOCKHAND_COMPOSE_TIMEOUT=900
DOCKHAND_EXPORT_METRICS=false
DOCKHAND_DISABLE_LOCAL_LOGIN=false
DOCKHAND_DISABLE_WHATS_NEW=false
DOCKHAND_SKIP_DF_COLLECTION=false
