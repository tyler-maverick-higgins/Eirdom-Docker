# ============================================================
# EIRDOM — ROOT ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# These variables are shared across multiple services.
# Container-specific variables live in docker/<service>/.env.example

# ============================================================
# GENERAL
# Consumed by: all containers via linuxserver.io base image
# ============================================================
TZ=America/Chicago
PUID=1000
PGID=1000
UMASK=022

# ============================================================
# DOMAIN
# Consumed by: Traefik (routing rules), all service labels
# NOTE: Docker Compose substitutes ${ROOT_DOMAIN} in compose
# files and labels. It is NOT substituted inside Traefik's
# mounted traefik.yml / dynamic configs — those are hardcoded
# to eirdom.homes (see AUDIT finding C1).
# ============================================================
ROOT_DOMAIN=eirdom.homes

# ============================================================
# STORAGE PATHS — three-tier layout (ADR-043)
#
# Tier 1  DOCKER_DATA_PATH  Service configs/SQLite  -> OS/Docker SSD
# Tier 3  MEDIA_PATH        Media libs + completed  -> 3TB WD Red
#                           downloads (= /media/arr today)
# Tier 2  DOWNLOADS_CACHE_PATH (in arr-stack/.env)  -> 250GB SSD
#                           qBittorrent incomplete only
#
# DOCKER_DATA_PATH is SHARED by every stack. Repointing it moves
# ALL config dirs off /media/arr to the OS SSD — that is the
# intended Tier-1 outcome, but do it as a coordinated migration:
#   stop stacks -> rsync /media/arr/config/ -> $DOCKER_DATA_PATH/
#   -> update this var -> restart.
#
# Hardlinks still work because completed downloads + libraries
# both live under MEDIA_PATH (Tier 3). Configs and incomplete
# downloads no longer need to share that filesystem.
#
# Inside containers, MEDIA_PATH mounts as /data:
#   /data/downloads/complete/{radarr,radarr-4k,sonarr,sonarr-4k,lidarr,manual}
#   /data/radarr/      (HD movie library)
#   /data/radarr-4k/   (4K movie library)
#   /data/sonarr/      (HD TV library)
#   /data/sonarr-4k/   (4K TV library)
#   /data/lidarr/      (music library)
# (qBittorrent incomplete mounts separately as /incomplete from Tier 2.)
# ============================================================
DOCKER_DATA_PATH=/opt/eirdom/appdata
MEDIA_PATH=/media/arr

# ============================================================
# SMTP
# Consumed by: Authentik, NetBox, Mealie (via env_file)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ============================================================
# BACKUP
# Consumed by: scripts/backup.sh
# ============================================================
BACKUP_PATH=/media/arr/backups
BACKUP_RETENTION_DAYS=14
NAS_HOST=
NAS_MOUNT=

# ============================================================
# NTFY
# Consumed by: scripts/backup.sh (completion notifications)
# Generate token with: docker exec ntfy ntfy token add tyler
# Leave blank to disable backup notifications
# ============================================================
NTFY_TOKEN=
