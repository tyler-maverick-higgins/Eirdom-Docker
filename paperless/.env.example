# =============================================================
# PAPERLESS-NGX — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (ROOT_DOMAIN, DOCKER_DATA_PATH, MEDIA_PATH,
# TZ, PUID, PGID) come from root .env

# =============================================================
# POSTGRESQL DATABASE
# =============================================================
PAPERLESS_DB_NAME=paperless
PAPERLESS_DB_USER=paperless
# Generate with: openssl rand -base64 32
PAPERLESS_DB_PASSWORD=

# =============================================================
# SECRET KEY
# Used for session signing and encryption
# Generate with: openssl rand -base64 50
# =============================================================
PAPERLESS_SECRET_KEY=

# =============================================================
# INITIAL ADMIN ACCOUNT
# Used ONLY on first container start to create the superuser
# DELETE THESE FROM .env AFTER FIRST LOGIN
# =============================================================
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=
PAPERLESS_ADMIN_EMAIL=tyler.eirdom@outlook.com
