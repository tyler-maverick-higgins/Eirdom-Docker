# =============================================================
# TRAEFIK — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (ROOT_DOMAIN, DOCKER_DATA_PATH) come
# from root .env

# =============================================================
# LET'S ENCRYPT
# =============================================================
# Email address for Let's Encrypt certificate notifications
# Used for expiry warnings and account recovery
TRAEFIK_ACME_EMAIL=

# =============================================================
# CLOUDFLARE DNS CHALLENGE
# Used by Traefik to issue wildcard cert for *.eirdom.homes
#
# CF_API_TOKEN — Create at dash.cloudflare.com → Profile →
#   API Tokens → Create Token → Edit zone DNS template
#   Permissions required:
#     Zone / DNS / Edit
#     Zone / Zone / Read
#   Zone Resources: Include → Specific zone → eirdom.homes
#
# CF_ZONE_ID — Found in Cloudflare dashboard →
#   eirdom.homes → Overview → right sidebar → Zone ID
# =============================================================
CF_API_TOKEN=
CF_ZONE_ID=

# =============================================================
# TRAEFIK DASHBOARD
# Basic auth is NOT used — Authentik ForwardAuth protects
# the dashboard instead. No credentials needed here.
# Dashboard URL: https://traefik.eirdom.homes
# Access: VLAN 10 only (enforced by chain-admin middleware)
# =============================================================
