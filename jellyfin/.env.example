# =============================================================
# JELLYFIN STACK — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (TZ, PUID, PGID, ROOT_DOMAIN,
# DOCKER_DATA_PATH, MEDIA_PATH) come from root .env

# =============================================================
# JELLYSTAT DATABASE
# =============================================================
JELLYSTAT_DB_NAME=jellystat
JELLYSTAT_DB_USER=jellystat
# Generate with: openssl rand -base64 32
JELLYSTAT_DB_PASSWORD=

# Generate with: openssl rand -base64 32
JELLYSTAT_JWT_SECRET=

# =============================================================
# JELLYFIN API KEY
# Generated in Jellyfin after initial setup:
#   Dashboard → API Keys → Add API Key → name it "jellystat"
# Fill in here for reference — entered in Jellystat UI directly
# =============================================================
JELLYFIN_API_KEY=

# =============================================================
# JELLYFIN LDAP (reference — configured in Jellyfin UI)
# The LDAP Authentication Plugin connects Jellyfin to AD.
# These values are configured inside Jellyfin's plugin settings,
# not consumed directly by the container.
#
# LDAP Server:    10.1.10.10 (EIRDOM-DC-01)
# LDAP Port:      389
# LDAP Base DN:   DC=ad,DC=eirdom,DC=homes
# LDAP Bind User: CN=jellyfin-svc,OU=Service Accounts,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
# Search Filter:  (&(objectClass=user)(memberOf=CN=Jellyfin-Users,OU=Security Groups,OU=Groups,OU=Eirdom,DC=ad,DC=eirdom,DC=homes))
# Admin Filter:   memberOf=CN=Jellyfin-Admins,OU=Security Groups,OU=Groups,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
#
# Required AD groups to create before enabling LDAP:
#   CN=Jellyfin-Users  — standard streaming access
#   CN=Jellyfin-Admins — full admin access
#   Both in: OU=Security Groups,OU=Groups,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
# =============================================================
JELLYFIN_LDAP_BIND_PASSWORD=