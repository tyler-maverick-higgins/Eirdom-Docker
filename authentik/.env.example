# =============================================================
# AUTHENTIK — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (ROOT_DOMAIN, DOCKER_DATA_PATH,
# SMTP_* settings) come from root .env

# =============================================================
# POSTGRESQL DATABASE
# =============================================================
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik
# Generate with: openssl rand -base64 32
AUTHENTIK_DB_PASSWORD=

# =============================================================
# AUTHENTIK SECRET KEY
# Used for session signing and encryption
# CRITICAL — generate once and never change after first start
# Changing this invalidates all existing sessions
#
# Generate with: openssl rand -base64 60
# =============================================================
AUTHENTIK_SECRET_KEY=

# =============================================================
# SMTP — inherited from root .env
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD,
# SMTP_FROM_EMAIL are all defined in root .env
# No SMTP config needed here
# =============================================================

# =============================================================
# ACTIVE DIRECTORY LDAP INTEGRATION
# These are reference values used when configuring the LDAP
# source in the Authentik admin UI — not consumed directly
# by the container. Stored here for documentation purposes.
#
# LDAP Server:    10.1.10.10 (EIRDOM-DC-01)
# LDAP Port:      389 (STARTTLS) or 636 (LDAPS)
# Base DN:        DC=ad,DC=eirdom,DC=homes
# Bind DN:        CN=authentik-svc,OU=Service Accounts,DC=ad,DC=eirdom,DC=homes
# User filter:    (&(objectClass=user)(!(objectClass=computer)))
# Group filter:   (objectClass=group)
# User OU:        OU=Users,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
#
# Create a dedicated service account in AD for Authentik LDAP
# binding. Use a strong password and store in password manager.
# =============================================================
AUTHENTIK_LDAP_BIND_PASSWORD=