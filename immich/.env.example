# =============================================================
# IMMICH — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (ROOT_DOMAIN, DOCKER_DATA_PATH, MEDIA_PATH,
# TZ) come from root .env

# =============================================================
# IMMICH VERSION
# REQUIRED — pin a specific release. Do NOT use "release": auto-
# updates can break the database through schema migrations.
# Current versions: github.com/immich-app/immich/releases
# (e.g. IMMICH_VERSION=v1.140.0)
# =============================================================
IMMICH_VERSION=

# =============================================================
# POSTGRESQL DATABASE
# Uses the immich-app/postgres (VectorChord) image — see
# docker-compose.yml. The old pgvecto.rs extension is deprecated.
# =============================================================
IMMICH_DB_NAME=immich
IMMICH_DB_USER=immich
# Generate with: openssl rand -base64 32
IMMICH_DB_PASSWORD=

# =============================================================
# NOTES
# =============================================================
# Immich does not use a SECRET_KEY env var — session security
# is handled internally.
#
# Initial admin account is created at first login:
# https://photos.eirdom.homes
# The first account registered becomes the admin account.
# Create the admin account BEFORE sharing the URL with family.
#
# Family members create their own accounts or you invite them
# via the admin UI → Administration → Users → Create User
#
# Mobile app server URL: https://photos.eirdom.homes
# Works both on the home network and externally via Cloudflare Tunnel
