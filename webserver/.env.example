# =============================================================
# WEBSERVER STACK — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (TZ, PUID, PGID, ROOT_DOMAIN,
# DOCKER_DATA_PATH) come from root .env

# =============================================================
# MARIADB — DATABASE
# =============================================================

# Root password — used only for initial setup and Adminer
# Generate a strong random password and store in password manager
WP_DB_ROOT_PASSWORD=

# WordPress database name — no spaces, lowercase recommended
WP_DB_NAME=wordpress

# WordPress database user — separate from root, limited privileges
WP_DB_USER=wordpress

# WordPress database user password
# Generate a strong random password — different from root password
WP_DB_PASSWORD=

# WordPress table prefix — change from default wp_ for security
# Use letters and underscore only (e.g. eirdom_)
WP_TABLE_PREFIX=eirdom_

# =============================================================
# WORDPRESS
# =============================================================

# WordPress site URL — must match your ROOT_DOMAIN in root .env
# Include https:// and no trailing slash
WP_SITE_URL=https://eirdom.homes

# WordPress admin email — used for admin notifications
WP_ADMIN_EMAIL=

# WordPress admin username — do not use "admin" (common attack target)
WP_ADMIN_USER=

# WordPress admin password — store in password manager
WP_ADMIN_PASSWORD=

# =============================================================
# SMTP — GMAIL APP PASSWORD
# =============================================================
# Setup instructions:
#   1. Create a dedicated Gmail account (e.g. eirdom.family@gmail.com)
#   2. Enable 2-Factor Authentication on the account
#   3. Go to Google Account → Security → App Passwords
#   4. Generate an app password for "Mail" / "Other (custom name)"
#   5. Enter the 16-character app password below (no spaces)
#
# SMTP settings for WordPress (used by WP Mail SMTP plugin):
#   Host:       smtp.gmail.com
#   Port:       587
#   Encryption: TLS (STARTTLS)
#   Auth:       Yes

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Eirdom Family