# =============================================================
# ARR STACK — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (TZ, PUID, PGID, ROOT_DOMAIN,
# DOCKER_DATA_PATH, MEDIA_PATH) come from root .env
#
# Storage tiers (ADR-043):
#   DOCKER_DATA_PATH (root .env) Tier 1 — configs, OS/Docker SSD.
#       Repoint to the OS SSD. It is shared by ALL stacks, so
#       moving it migrates every stack's config dirs (intended —
#       see README "Storage Layout").
#   MEDIA_PATH (root .env) Tier 3 — completed media + libraries.
#       UNCHANGED: already /media/arr, which is the 3TB WD Red.
#   DOWNLOADS_CACHE_PATH (below) Tier 2 — in-progress downloads,
#       250GB SSD. ARR-stack-specific; set it here.

# =============================================================
# STORAGE — Tier 2 download cache (ADR-043)
# Mount the 250GB SSD on the host, then point this at it.
# qBittorrent's incomplete downloads live here and clear
# automatically as torrents finish (moved to Tier 3 on the 3TB).
# =============================================================
DOWNLOADS_CACHE_PATH=/mnt/downloads-cache

# =============================================================
# AIRVPN WIREGUARD VPN (ADR-042)
# Generate a WireGuard config at:
#   airvpn.org -> Client Area -> Config Generator
#   - Select WireGuard, pick a device, choose a server country
#   - AirVPN issues a PresharedKey (TorGuard did not)
#
# From the generated [Interface] section:
#   PrivateKey   = -> WIREGUARD_PRIVATE_KEY
#   PresharedKey = -> WIREGUARD_PRESHARED_KEY
#   Address      = -> WIREGUARD_ADDRESSES
#
# The server is chosen by country filter, NOT an endpoint IP.
# Gluetun ships AirVPN's server keys, so no server public key
# and no endpoint IP/port are needed.
#   VPN_SERVER_COUNTRIES = e.g. Canada (lowest latency from MN)
#
# Confirm the required vars at:
#   github.com/qdm12/gluetun-wiki -> setup/providers/airvpn
# =============================================================
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=
VPN_SERVER_COUNTRIES=Canada

# =============================================================
# AIRVPN PORT FORWARDING (ADR-042)
# Reserve a port (>= 2048) in the AirVPN Client Area -> Ports.
# It is account-bound and persists across servers/reconnects.
# Set qBittorrent's Listening Port to this SAME value:
#   Settings -> Connection -> Listening Port
# =============================================================
VPN_FORWARDED_PORT=

# =============================================================
# API KEYS
# Generated automatically on first start for each service.
# Settings -> General -> API Key in each app's web UI.
# Fill in after initial deployment — needed for Recyclarr
# and cross-service connections.
# =============================================================
RADARR_API_KEY=
RADARR_4K_API_KEY=
SONARR_API_KEY=
SONARR_4K_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=

# =============================================================
# QBITTORRENT
# Temporary password printed in container logs on first run:
#   docker logs qbittorrent 2>&1 | grep -i "password"
# Change immediately after first login in Settings -> Web UI.
# =============================================================
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=
