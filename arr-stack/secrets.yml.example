# =============================================================
# Recyclarr Secrets
# Copy this file to secrets.yml and fill in your API keys
# NEVER commit secrets.yml — it is gitignored
#
# Find API keys in each app:
#   Settings → General → API Key
#
# Place the filled-in secrets.yml at:
#   $DOCKER_DATA_PATH/recyclarr/secrets.yml
#   (Tier 1 — OS/Docker SSD, e.g. /opt/eirdom/appdata/recyclarr/)
# =============================================================

radarr_api_key: YOUR_RADARR_API_KEY
radarr_4k_api_key: YOUR_RADARR_4K_API_KEY
sonarr_api_key: YOUR_SONARR_API_KEY
sonarr_4k_api_key: YOUR_SONARR_4K_API_KEY