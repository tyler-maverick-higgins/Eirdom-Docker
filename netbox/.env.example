# =============================================================
# NETBOX — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (TZ, ROOT_DOMAIN, DOCKER_DATA_PATH,
# SMTP_*) come from root .env

# =============================================================
# POSTGRESQL DATABASE
# =============================================================
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
# Generate with: openssl rand -base64 32
NETBOX_DB_PASSWORD=

# =============================================================
# REDIS
# =============================================================
# Generate with: openssl rand -base64 32
NETBOX_REDIS_PASSWORD=

# =============================================================
# NETBOX SECRET KEY
# Used for session signing and cryptographic operations
# CRITICAL — generate once and never change after first start
# Changing this invalidates all active sessions
#
# Generate with: openssl rand -base64 50
# =============================================================
NETBOX_SECRET_KEY=

# =============================================================
# ACTIVE DIRECTORY LDAP
# Bind account for NetBox to search AD
# Create a dedicated read-only service account in AD:
#   CN=netbox-svc,OU=Service Accounts,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
#
# Required AD groups to create before enabling LDAP auth:
#   CN=NetBox-Users  — baseline access (required to log in)
#   CN=NetBox-Staff  — staff access (can manage objects)
#   CN=NetBox-Admins — superuser access (full admin)
#   All groups in: OU=Security Groups,OU=Groups,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
# =============================================================
NETBOX_LDAP_BIND_DN=CN=netbox-svc,OU=Service Accounts,OU=Eirdom,DC=ad,DC=eirdom,DC=homes
NETBOX_LDAP_BIND_PASSWORD=

# =============================================================
# UNIFI SYNC PLUGIN
# Credentials are configured through the NetBox UI after setup
# Navigate to: Plugins → UniFi Sync → Settings → Add Controller
#
# Reference values (not consumed directly by container):
#   Controller URL:  https://10.1.1.1
#   Read-only user:  Create a dedicated read-only local account
#                    on the UDM-Pro-Max for NetBox sync
#                    Do NOT use your admin account
#   Site name:       Eirdom (matches your UniFi site name)
# =============================================================
# NETBOX_UNIFI_CONTROLLER_URL=https://10.1.1.1
# NETBOX_UNIFI_USERNAME=
# NETBOX_UNIFI_PASSWORD=