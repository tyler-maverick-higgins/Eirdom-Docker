# =============================================================
# MEALIE — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file — only .env.example
# Shared variables (ROOT_DOMAIN, DOCKER_DATA_PATH, TZ,
# PUID, PGID, SMTP_*) come from root .env

# =============================================================
# POSTGRESQL DATABASE
# =============================================================
MEALIE_DB_NAME=mealie
MEALIE_DB_USER=mealie
# Generate with: openssl rand -base64 32
MEALIE_DB_PASSWORD=

# =============================================================
# INITIAL ADMIN ACCOUNT
# Used on first container start to create the default user
# Change the password immediately after first login
# ALLOW_SIGNUP is set to false so only invited users can join
# =============================================================
MEALIE_ADMIN_EMAIL=tyler.eirdom@outlook.com
MEALIE_ADMIN_PASSWORD=
